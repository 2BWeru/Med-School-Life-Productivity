# Neon Postgres connection string (from your Neon project dashboard)
# Example: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
SESSION_SECRET=

# Used only by scripts/seed.ts to create your personal login on first setup.
SEED_USER_EMAIL=you@example.com
SEED_USER_NAME="Your Name"
SEED_USER_PASSWORD=change-me-please
